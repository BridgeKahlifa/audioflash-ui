# Copy this file to .env and fill in your values
# Get an API key at https://openrouter.ai
EXPO_PUBLIC_OPENROUTER_API_KEY=

# Model to use via OpenRouter (swap any time; no code changes needed)
# Examples: anthropic/claude-3-5-haiku, openai/gpt-4o-mini, google/gemini-flash-1.5
EXPO_PUBLIC_AI_MODEL=anthropic/claude-haiku-4-5

# Frontend auth mode. Use "dev" to bypass Supabase login and rely on the API's dev auth path.
EXPO_PUBLIC_AUTH_MODE=supabase
EXPO_PUBLIC_DEV_USER_ID=
EXPO_PUBLIC_DEV_USER_EMAIL=

# Supabase project settings
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
