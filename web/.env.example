NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

RESEND_API_KEY=re_your-api-key
RESEND_FROM_ADDRESS=you@yourdomain.com  # omit to use onboarding@resend.dev for testing

BROADCAST_SECRET=a-long-random-secret  # used to protect the /api/broadcast endpoint
UNSUBSCRIBE_SECRET=a-long-random-secret  # used to sign unsubscribe tokens — never change this or existing links break

NEXT_PUBLIC_BASE_URL=https://audioflash.ai  # omit in dev, falls back to the request host
